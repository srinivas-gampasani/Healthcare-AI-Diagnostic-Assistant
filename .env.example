# ============================================================
# Healthcare AI Diagnostic Assistant — Environment Config
# ============================================================

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Azure OpenAI (alternative to OpenAI)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4

# API Server
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-this-to-a-random-secret-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite+aiosync:///./db/healthcare.db

# FAISS Vector Store
FAISS_INDEX_PATH=db/faiss_index
FAISS_METADATA_PATH=db/faiss_metadata.json

# HIPAA / Compliance
AUDIT_LOG_PATH=outputs/audit.log
PHI_MASKING_ENABLED=true
ENCRYPTION_KEY=generate-with-cryptography-fernet

# HL7 FHIR
FHIR_SERVER_URL=http://localhost:8080/fhir
FHIR_AUTH_TOKEN=

# Logging
LOG_LEVEL=INFO
